APP_NAME=KislayApp
APP_ENV=production
HTTP_PORT=9000
GATEWAY_PORT=9008
DISCOVERY_PORT=9090

# Laravel-style database selection
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kislayphp
DB_USERNAME=root
DB_PASSWORD=

# SQLite
SQLITE_DB_PATH=/app/storage/database.sqlite

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=kislayphp
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4

# MariaDB
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_DATABASE=kislayphp
MARIADB_USERNAME=root
MARIADB_PASSWORD=
MARIADB_CHARSET=utf8mb4

# PostgreSQL
PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_DATABASE=kislayphp
PGSQL_USERNAME=postgres
PGSQL_PASSWORD=

PIE_VERSION=1.3.8
CORE_VERSION=0.0.3
GATEWAY_VERSION=0.0.2
DISCOVERY_VERSION=0.0.3
QUEUE_VERSION=v0.1.1
METRICS_VERSION=v0.1.1
CONFIG_VERSION=v0.1.1
EVENTBUS_VERSION=0.0.1
PERSISTENCE_VERSION=0.0.1

# Optional production hard-fail mode (comma-separated package names).
# Example:
# REQUIRED_EXTENSIONS=kislayphp/discovery,kislayphp/gateway,kislayphp/persistence
REQUIRED_EXTENSIONS=
